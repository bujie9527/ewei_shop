#
# EweiShop (WeEngine + ewei_shopv2) docker compose env
# Copy to .env and adjust values before running.
#

# Project name prefix for docker resources
COMPOSE_PROJECT_NAME=ewei_shop

# MySQL
MYSQL_DATABASE=we7
MYSQL_USER=we7
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# Container exposed ports (avoid 80/443 to not affect WordPress)
# Bind to localhost only; use existing host nginx/apache as reverse proxy.
HTTP_BIND=127.0.0.1:18080

# App
TZ=Asia/Shanghai
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=50M
PHP_POST_MAX_SIZE=50M
